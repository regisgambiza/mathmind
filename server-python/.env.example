# MathMind Python Server Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=4000
# Use PYTHON_PORT to run on a different port if needed
# PYTHON_PORT=4001

# Security
SECRET_KEY=mathmind-secret-key-change-in-production

# Database (relative to server.py location)
# DATABASE_PATH=./mathmind.db

# CORS Origins (comma-separated for production)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama AI (if using local AI)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Logging
# LOG_LEVEL=INFO

# ============================================
# Google Classroom Integration (Phase 2)
# ============================================

# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Allowed School Email Domains (comma-separated)
# Only emails from these domains can log in
ALLOWED_EMAIL_DOMAINS=yourschool.edu,yourschool.k12.us
