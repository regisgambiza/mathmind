# MathMind Python Server Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
# Use PYTHON_PORT to run on a different port if needed
# PYTHON_PORT=4001

# Security
SECRET_KEY=mathmind-secret-key-change-in-production

# Google OAuth Configuration
# Get your Google Client ID from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Database (relative to server.py location)
# DATABASE_PATH=./mathmind.db

# CORS Origins (comma-separated for production)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama AI (if using local AI)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Logging
# LOG_LEVEL=INFO
