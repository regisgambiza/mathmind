# OpenRouter API Key (required for AI features)
# Get your free API key from: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_api_key_here

# Model chain with automatic fallback (comma-separated list)
# Format: primary,fallback1,fallback2
# Default: openai/gpt-4o-mini -> google/gemini-2.0-flash-001 -> qwen/qwen3-235b-a22b-thinking-2507
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini,google/gemini-2.0-flash-001,qwen/qwen3-235b-a22b-thinking-2507
